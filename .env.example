# Bu faylni .env deb nomlab o'zgartiring

# Database paroli (o'zingiz o'ylab toping, kamida 16 belgi)
DB_PASSWORD=yourStrongPassword123!

# App secret keys (kamida 32 belgi, tasodifiy)
SECRET_KEY=your-super-secret-key-change-this-32chars
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-32chars

# Frontend manzili (serveringiz IP yoki domain)
ALLOWED_ORIGINS=http://localhost,http://YOUR_SERVER_IP
