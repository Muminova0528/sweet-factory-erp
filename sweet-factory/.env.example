# =============================================================
# Sweet Factory Cloud ERP — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Application ---
APP_NAME="Sweet Factory ERP"
APP_VERSION="1.0.0"
APP_ENV="development"  # development | staging | production
DEBUG=true
SECRET_KEY="your-super-secret-key-change-in-production-minimum-32-chars"
ALLOWED_ORIGINS="http://localhost,http://localhost:80,https://sweetfactory.com"

# --- JWT ---
JWT_SECRET_KEY="jwt-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=sweet_factory_db
DATABASE_USER=sweet_factory_user
DATABASE_PASSWORD=StrongPass@2024!
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# --- Redis (Cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisPass@2024!
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# --- AWS (Production) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=sweet-factory-assets
AWS_RDS_HOST=sweet-factory-db.xxxx.us-east-1.rds.amazonaws.com

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@sweetfactory.com
SMTP_PASSWORD=smtp-password

# --- pgAdmin ---
PGADMIN_EMAIL=admin@sweetfactory.com
PGADMIN_PASSWORD=PgAdmin@2024!

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:80","https://sweetfactory.com"]
